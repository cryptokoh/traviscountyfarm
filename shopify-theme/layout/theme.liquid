<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="theme-color" content="{{ settings.color_primary }}">

  <title>
    {%- if page_title -%}
      {{ page_title }}
      {%- if current_page != 1 %} &ndash; {{ 'general.pagination.page' | t: number: current_page }}{% endif -%}
      &ndash; {{ shop.name }}
    {%- else -%}
      {{ shop.name }}
    {%- endif -%}
  </title>

  {% render 'meta-tags' %}
  {% render 'social-meta' %}

  <link rel="canonical" href="{{ canonical_url }}">

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 96 }}">
  {%- else -%}
    <link rel="icon" type="image/svg+xml" href="{{ 'favicon.svg' | asset_url }}">
  {%- endif -%}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

  {{ settings.font_heading | font_face: font_display: 'swap' }}
  {{ settings.font_accent | font_face: font_display: 'swap' }}
  {{ settings.font_body | font_face: font_display: 'swap' }}

  <style>{% render 'css-variables' %}</style>

  {{ 'base.css' | asset_url | stylesheet_tag }}

  {{ content_for_header }}

  <script>
    document.documentElement.className = document.documentElement.className.replace('no-js', 'js');
    window.tcf = window.tcf || {};
    window.tcf.routes = {
      cart_url: '{{ routes.cart_url }}',
      cart_add_url: '{{ routes.cart_add_url }}',
      cart_change_url: '{{ routes.cart_change_url }}',
      cart_update_url: '{{ routes.cart_update_url }}',
      search_url: '{{ routes.search_url }}'
    };
    window.tcf.cartType = {{ settings.cart_type | json }};
    window.tcf.moneyFormat = {{ shop.money_format | json }};
  </script>
</head>

<body class="template-{{ template.name | handle }}{% if template.suffix %} template-{{ template.name }}-{{ template.suffix | handle }}{% endif %}">
  <a href="#main" class="visually-hidden skip-to-content">{{ 'general.skip_to_content' | t }}</a>

  {% sections 'header-group' %}

  <main id="main" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {% sections 'footer-group' %}

  {%- if settings.cart_type == 'drawer' -%}
    {% section 'cart-drawer' %}
  {%- endif -%}

  <script src="{{ 'global.js' | asset_url }}" defer></script>
</body>
</html>
