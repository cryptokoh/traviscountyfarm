{{ 'component-newsletter.css' | asset_url | stylesheet_tag }}

<section class="cta-section">
  <div class="container">
    <div class="cta-card">
      <div class="cta-content">
        {%- if section.settings.heading != blank -%}
          <h2 class="cta-title">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <p class="cta-description">{{ section.settings.description }}</p>
        {%- endif -%}
      </div>

      {% form 'customer', id: 'newsletter-form', class: 'cta-form' %}
        {%- if form.posted_successfully? -%}
          <div class="newsletter-success">
            <p>{{ 'general.newsletter.success' | t }}</p>
          </div>
        {%- endif -%}

        {%- if form.errors -%}
          <div class="newsletter-error">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        <input type="hidden" name="contact[tags]" value="newsletter">
        <input type="hidden" name="contact[accepts_marketing]" value="true">

        <div class="cta-input-group">
          <input
            type="email"
            name="contact[email]"
            placeholder="{{ 'general.newsletter.email_placeholder' | t }}"
            required
            autocomplete="email"
            aria-label="{{ 'general.newsletter.email_placeholder' | t }}"
            {% if form.posted_successfully? %}value=""{% endif %}
          >
          <button type="submit" class="btn btn-primary">
            <span>{{ 'general.newsletter.subscribe' | t }}</span>
            {% render 'icon-arrow' %}
          </button>
        </div>
        <p class="cta-note">{{ 'general.newsletter.note' | t }}</p>
      {% endform %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "class": "section-newsletter",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Join the TCF Family"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Be the first to know when our products launch. Get farm updates, seasonal offerings, and exclusive early access."
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}
