{{ 'component-footer.css' | asset_url | stylesheet_tag }}

<footer class="footer" id="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <div class="footer-logo">
          <div class="logo-icon" style="width: 32px; height: 32px;">
            {% render 'icon-logo' %}
          </div>
          <span>{{ shop.name }}</span>
        </div>
        {%- if section.settings.tagline != blank -%}
          <p class="footer-tagline">{{ section.settings.tagline }}</p>
        {%- endif -%}
      </div>

      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'link_list' -%}
            <div class="footer-links" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}
                <h4>{{ block.settings.heading }}</h4>
              {%- endif -%}
              {%- if block.settings.menu != blank -%}
                <ul>
                  {%- for link in block.settings.menu.links -%}
                    <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </div>

          {%- when 'contact' -%}
            <div class="footer-contact" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}
                <h4>{{ block.settings.heading }}</h4>
              {%- endif -%}
              <div class="contact-details">
                {%- if block.settings.address != blank -%}
                  <div class="contact-item">
                    <span class="contact-icon">{% render 'icon-location' %}</span>
                    <span>{{ block.settings.address }}</span>
                  </div>
                {%- endif -%}
                {%- if block.settings.email != blank -%}
                  <div class="contact-item">
                    <span class="contact-icon">{% render 'icon-mail' %}</span>
                    <a href="mailto:{{ block.settings.email }}">{{ block.settings.email }}</a>
                  </div>
                {%- endif -%}
              </div>
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>

    <div class="footer-bottom">
      <p>{{ 'sections.footer.copyright' | t: year: 'now' | date: '%Y', shop_name: shop.name }}</p>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "class": "section-footer",
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "From our land to your hands. Small-batch artisan goods crafted with care in Travis County, Texas."
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Link list",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Quick Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu",
          "default": "footer"
        }
      ]
    },
    {
      "type": "contact",
      "name": "Contact info",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Get in Touch"
        },
        {
          "type": "text",
          "id": "address",
          "label": "Address",
          "default": "Travis County, Texas"
        },
        {
          "type": "text",
          "id": "email",
          "label": "Email",
          "default": "hello@traviscountyfarm.com"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "link_list" },
      { "type": "contact" }
    ]
  }
}
{% endschema %}
