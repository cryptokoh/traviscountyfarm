<section class="page-404-section">
  <div class="container">
    <div class="page-404">
      <div class="page-404__icon" aria-hidden="true">
        <svg width="120" height="120" viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="60" cy="60" r="58" stroke="var(--color-border)" stroke-width="2" stroke-dasharray="6 4"/>
          <path d="M40,75 Q40,50 60,45 Q80,50 80,75" fill="var(--color-primary)" opacity="0.15" stroke="var(--color-primary)" stroke-width="1.5"/>
          <path d="M55,45 Q57,35 60,30 Q63,35 65,45" fill="var(--color-primary)" opacity="0.2"/>
          <ellipse cx="60" cy="78" rx="12" ry="3" fill="var(--color-secondary)" opacity="0.15"/>
          <circle cx="35" cy="30" r="2" fill="var(--color-primary)" opacity="0.3"/>
          <circle cx="88" cy="35" r="1.5" fill="var(--color-primary)" opacity="0.25"/>
          <circle cx="75" cy="25" r="1" fill="var(--color-primary)" opacity="0.2"/>
        </svg>
      </div>

      <h1 class="page-404__heading">Page Not Found</h1>
      <p class="page-404__message">
        Looks like this page wandered off the farm. The content you're looking for may have been moved or no longer exists.
      </p>

      <form action="{{ routes.search_url }}" method="get" role="search" class="page-404__search">
        <label class="visually-hidden" for="search-404">{{ 'search.title' | t }}</label>
        <div class="page-404__search-inner">
          <input
            class="form-input page-404__search-input"
            type="search"
            id="search-404"
            name="q"
            placeholder="{{ 'search.placeholder' | t }}"
          >
          <button type="submit" class="btn btn-primary">
            {{ 'search.title' | t }}
          </button>
        </div>
      </form>

      <a href="{{ routes.all_products_collection_url }}" class="btn btn-secondary page-404__shop-btn">
        {{ 'cart.continue_shopping' | t }}
        {% render 'icon-arrow' %}
      </a>
    </div>
  </div>
</section>

<style>
  .page-404-section {
    padding: var(--spacing-4xl) 0;
    background: var(--color-bg);
    min-height: 60vh;
    display: flex;
    align-items: center;
  }

  .page-404 {
    text-align: center;
    max-width: 540px;
    margin: 0 auto;
  }

  .page-404__icon {
    margin-bottom: var(--spacing-xl);
  }

  .page-404__heading {
    font-family: var(--font-display);
    font-size: var(--text-5xl);
    font-weight: var(--font-heading-weight);
    color: var(--color-text);
    margin-bottom: var(--spacing-md);
  }

  .page-404__message {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: var(--spacing-2xl);
  }

  .page-404__search {
    margin-bottom: var(--spacing-xl);
  }

  .page-404__search-inner {
    display: flex;
    gap: var(--spacing-sm);
    max-width: 440px;
    margin: 0 auto;
  }

  .page-404__search-input {
    flex: 1;
  }

  .page-404__shop-btn {
    display: inline-flex;
  }

  @media (max-width: 640px) {
    .page-404__heading {
      font-size: var(--text-4xl);
    }

    .page-404__message {
      font-size: var(--text-base);
    }

    .page-404__search-inner {
      flex-direction: column;
    }
  }
</style>

{% schema %}
{
  "name": "404 Page",
  "tag": "section",
  "class": "section-404"
}
{% endschema %}
