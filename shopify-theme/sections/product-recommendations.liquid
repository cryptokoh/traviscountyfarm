{{ 'component-card-product.css' | asset_url | stylesheet_tag }}

<section class="product-recommendations" data-product-id="{{ product.id }}">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">
        {{ section.settings.heading | default: 'products.recommendations.title' | t }}
      </h2>
    </div>

    <div class="products-grid" id="ProductRecommendations">
      {%- if recommendations.performed and recommendations.products_count > 0 -%}
        {%- for product in recommendations.products limit: 4 -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

<script>
  (function() {
    var section = document.querySelector('.product-recommendations');
    if (!section) return;

    var productId = section.getAttribute('data-product-id');
    if (!productId) return;

    var url = '/recommendations/products.json?product_id=' + productId + '&limit=4&section_id={{ section.id }}';

    fetch(url)
      .then(function(res) { return res.json(); })
      .then(function(data) {
        if (data.html) {
          /* Replace the section content with server-rendered HTML */
          var temp = document.createElement('div');
          temp.innerHTML = data.html;
          var newGrid = temp.querySelector('.products-grid');
          var currentGrid = document.getElementById('ProductRecommendations');
          if (newGrid && currentGrid) {
            currentGrid.innerHTML = newGrid.innerHTML;
          }
        }
      })
      .catch(function(err) {
        console.error('Failed to load product recommendations:', err);
      });
  })();
</script>

{% schema %}
{
  "name": "Product Recommendations",
  "class": "section-product-recommendations",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "You May Also Like"
    }
  ],
  "presets": [
    {
      "name": "Product Recommendations"
    }
  ]
}
{% endschema %}
