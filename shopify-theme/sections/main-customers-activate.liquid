{{ 'component-customer.css' | asset_url | stylesheet_tag }}

<section class="customer-section">
  <div class="customer-section--narrow">
    <h1 class="customer-title">{{ 'customer.activate_account.title' | t }}</h1>
    <p class="customer-subtitle">{{ 'customer.activate_account.subtext' | t }}</p>

    <div class="customer-form">
      {%- form 'activate_customer_password' -%}
        {%- if form.errors -%}
          <div class="customer-form__errors" role="alert">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        <div class="form-field">
          <label for="activate-password" class="form-label">
            {{ 'customer.activate_account.password' | t }}
          </label>
          <input
            type="password"
            id="activate-password"
            name="customer[password]"
            class="form-input"
            autocomplete="new-password"
            required
          >
        </div>

        <div class="form-field">
          <label for="activate-password-confirm" class="form-label">
            {{ 'customer.activate_account.password_confirm' | t }}
          </label>
          <input
            type="password"
            id="activate-password-confirm"
            name="customer[password_confirmation]"
            class="form-input"
            autocomplete="new-password"
            required
          >
        </div>

        <div class="customer-form__actions">
          <button type="submit" class="btn btn-primary btn-full">
            {{ 'customer.activate_account.submit' | t }}
          </button>
        </div>
      {%- endform -%}

      <div class="customer-form__footer">
        <p>
          <a href="{{ routes.account_login_url }}">{{ 'customer.activate_account.cancel' | t }}</a>
        </p>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Activate Account",
  "tag": "section",
  "class": "section-customer-activate"
}
{% endschema %}
