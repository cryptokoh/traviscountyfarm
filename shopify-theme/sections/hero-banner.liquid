{{ 'component-hero.css' | asset_url | stylesheet_tag }}

<section class="hero">
  <div class="hero-bg">
    <div class="hero-gradient"></div>
    <div class="hero-pattern"></div>
  </div>
  <div class="hero-content container">
    <div class="hero-text">
      {%- if section.settings.badge_text != blank -%}
        <div class="hero-badge">
          {% render 'icon-star' %}
          {{ section.settings.badge_text }}
        </div>
      {%- endif -%}

      <h1 class="hero-title">{{ section.settings.heading }}</h1>

      {%- if section.settings.subheading != blank -%}
        <p class="hero-subtitle">{{ section.settings.subheading }}</p>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        <div class="hero-actions">
          <a href="{{ section.settings.button_link }}" class="btn btn-primary btn-lg">
            {{ section.settings.button_label }}
            {% render 'icon-arrow' %}
          </a>
        </div>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <div class="hero-stats">
          {%- for block in section.blocks -%}
            {%- if forloop.index > 1 -%}
              <div class="stat-divider"></div>
            {%- endif -%}
            <div class="hero-stat" {{ block.shopify_attributes }}>
              <span class="stat-number">{{ block.settings.number }}</span>
              <span class="stat-label">{{ block.settings.label }}</span>
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <div class="hero-visual">
      <svg class="hero-illustration" viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <defs>
          <linearGradient id="honeyGrad" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" style="stop-color:var(--color-primary);stop-opacity:0.3"/>
            <stop offset="100%" style="stop-color:var(--color-primary-light);stop-opacity:0.1"/>
          </linearGradient>
        </defs>
        <g transform="translate(200,200)">
          <polygon points="0,-60 52,-30 52,30 0,60 -52,30 -52,-30" fill="url(#honeyGrad)" stroke="var(--color-primary)" stroke-width="1.5" opacity="0.8"/>
          <polygon points="0,-60 52,-30 52,30 0,60 -52,30 -52,-30" fill="none" stroke="var(--color-primary)" stroke-width="1" opacity="0.4" transform="translate(78,45)"/>
          <polygon points="0,-60 52,-30 52,30 0,60 -52,30 -52,-30" fill="none" stroke="var(--color-primary)" stroke-width="1" opacity="0.4" transform="translate(-78,45)"/>
          <polygon points="0,-60 52,-30 52,30 0,60 -52,30 -52,-30" fill="none" stroke="var(--color-primary)" stroke-width="1" opacity="0.3" transform="translate(0,-90)"/>
          <polygon points="0,-60 52,-30 52,30 0,60 -52,30 -52,-30" fill="none" stroke="var(--color-primary)" stroke-width="1" opacity="0.3" transform="translate(78,-45)"/>
          <polygon points="0,-60 52,-30 52,30 0,60 -52,30 -52,-30" fill="none" stroke="var(--color-primary)" stroke-width="1" opacity="0.3" transform="translate(-78,-45)"/>
          <polygon points="0,-60 52,-30 52,30 0,60 -52,30 -52,-30" fill="none" stroke="var(--color-primary)" stroke-width="1" opacity="0.2" transform="translate(0,90)"/>
        </g>
        <g transform="translate(240,160) scale(0.8)">
          <ellipse cx="0" cy="0" rx="14" ry="10" fill="var(--color-primary)" opacity="0.7"/>
          <ellipse cx="16" cy="0" rx="10" ry="8" fill="var(--color-primary-light)" opacity="0.6"/>
          <path d="M-2,-8 Q8,-20 18,-10" stroke="var(--color-primary)" stroke-width="1" fill="none" opacity="0.5"/>
          <path d="M-2,8 Q8,20 18,10" stroke="var(--color-primary)" stroke-width="1" fill="none" opacity="0.5"/>
        </g>
        <path d="M80,320 Q120,280 100,240" stroke="var(--color-secondary)" stroke-width="2" fill="none" opacity="0.4"/>
        <path d="M100,240 Q130,260 110,290" stroke="var(--color-secondary)" stroke-width="1.5" fill="var(--color-secondary)" opacity="0.15"/>
        <path d="M300,80 Q340,120 320,160" stroke="var(--color-secondary)" stroke-width="2" fill="none" opacity="0.3"/>
        <path d="M320,160 Q350,140 330,110" stroke="var(--color-secondary)" stroke-width="1.5" fill="var(--color-secondary)" opacity="0.1"/>
      </svg>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "class": "section-hero",
  "settings": [
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "Rooted in Travis County, TX"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "From Our Land to Your Hands"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Small-batch artisan honey, beeswax goods, and herbal remedies crafted with care on our Texas farm. Every product tells a story of land, bees, and tradition."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Explore Our Products"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "6"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Products"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "blocks": [
        { "type": "stat", "settings": { "number": "6", "label": "Products" } },
        { "type": "stat", "settings": { "number": "100%", "label": "Natural" } },
        { "type": "stat", "settings": { "number": "Made in", "label": "Texas" } }
      ]
    }
  ]
}
{% endschema %}
