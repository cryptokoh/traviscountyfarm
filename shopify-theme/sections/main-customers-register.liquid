{{ 'component-customer.css' | asset_url | stylesheet_tag }}

<section class="customer-section">
  <div class="customer-section--narrow">
    <h1 class="customer-title">{{ 'customer.register.title' | t }}</h1>

    <div class="customer-form">
      {%- form 'create_customer', novalidate: 'novalidate' -%}
        {%- if form.errors -%}
          <div class="customer-form__errors" role="alert">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        <div class="form-field">
          <label for="register-first-name" class="form-label">
            {{ 'customer.register.first_name' | t }}
          </label>
          <input
            type="text"
            id="register-first-name"
            name="customer[first_name]"
            class="form-input"
            autocomplete="given-name"
            required
          >
        </div>

        <div class="form-field">
          <label for="register-last-name" class="form-label">
            {{ 'customer.register.last_name' | t }}
          </label>
          <input
            type="text"
            id="register-last-name"
            name="customer[last_name]"
            class="form-input"
            autocomplete="family-name"
            required
          >
        </div>

        <div class="form-field">
          <label for="register-email" class="form-label">
            {{ 'customer.register.email' | t }}
          </label>
          <input
            type="email"
            id="register-email"
            name="customer[email]"
            class="form-input"
            autocomplete="email"
            autocapitalize="off"
            autocorrect="off"
            required
          >
        </div>

        <div class="form-field">
          <label for="register-password" class="form-label">
            {{ 'customer.register.password' | t }}
          </label>
          <input
            type="password"
            id="register-password"
            name="customer[password]"
            class="form-input"
            autocomplete="new-password"
            required
          >
        </div>

        <div class="customer-form__actions">
          <button type="submit" class="btn btn-primary btn-full">
            {{ 'customer.register.create' | t }}
          </button>
        </div>
      {%- endform -%}

      <div class="customer-form__footer">
        <p>
          {{ 'customer.register.already_have_account' | t }}
          <a href="{{ routes.account_login_url }}">{{ 'customer.login.sign_in' | t }}</a>
        </p>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Register",
  "tag": "section",
  "class": "section-customer-register"
}
{% endschema %}
