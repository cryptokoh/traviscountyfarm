{{ 'component-customer.css' | asset_url | stylesheet_tag }}

<section class="password-section">
  <div class="password-card">
    {%- if section.settings.logo != blank -%}
      <img
        src="{{ section.settings.logo | image_url: width: 200 }}"
        alt="{{ shop.name }}"
        width="200"
        height="auto"
        style="margin: 0 auto var(--spacing-xl);"
        loading="eager"
      >
    {%- else -%}
      <h1 class="password-card__title">{{ shop.name }}</h1>
    {%- endif -%}

    <h2 class="password-card__title">{{ 'password_page.title' | t }}</h2>
    <p class="password-card__subtitle">{{ 'password_page.subtitle' | t }}</p>

    {%- comment -%} Store password form {%- endcomment -%}
    {%- form 'storefront_password' -%}
      {%- if form.errors -%}
        <div class="customer-form__errors" role="alert">
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}

      <div class="form-field">
        <label for="store-password" class="form-label visually-hidden">
          {{ 'password_page.password_label' | t }}
        </label>
        <input
          type="password"
          id="store-password"
          name="password"
          class="form-input"
          placeholder="{{ 'password_page.password_label' | t }}"
          required
        >
      </div>

      <button type="submit" class="btn btn-primary btn-full">
        {{ 'password_page.enter' | t }}
      </button>
    {%- endform -%}

    {%- comment -%} Newsletter signup {%- endcomment -%}
    <hr class="password-card__divider">

    {% form 'customer', id: 'password-newsletter-form' %}
      {%- if form.posted_successfully? -%}
        <div class="customer-form__success" role="status">
          {{ 'general.newsletter.success' | t }}
        </div>
      {%- endif -%}

      {%- if form.errors -%}
        <div class="customer-form__errors" role="alert">
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}

      <input type="hidden" name="contact[tags]" value="newsletter, prospect">
      <input type="hidden" name="contact[accepts_marketing]" value="true">

      <div class="form-field">
        <label for="password-newsletter-email" class="form-label visually-hidden">
          {{ 'general.newsletter.email_placeholder' | t }}
        </label>
        <input
          type="email"
          id="password-newsletter-email"
          name="contact[email]"
          class="form-input"
          placeholder="{{ 'general.newsletter.email_placeholder' | t }}"
          autocomplete="email"
          required
        >
      </div>

      <button type="submit" class="btn btn-secondary btn-full">
        {{ 'general.newsletter.subscribe' | t }}
      </button>
    {% endform %}

    <p class="password-card__powered">{{ 'password_page.powered_by' | t }}</p>
  </div>
</section>

{% schema %}
{
  "name": "Password",
  "tag": "section",
  "class": "section-password",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    }
  ]
}
{% endschema %}
