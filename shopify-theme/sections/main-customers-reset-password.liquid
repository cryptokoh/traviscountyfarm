{{ 'component-customer.css' | asset_url | stylesheet_tag }}

<section class="customer-section">
  <div class="customer-section--narrow">
    <h1 class="customer-title">{{ 'customer.reset_password.title' | t }}</h1>
    <p class="customer-subtitle">{{ 'customer.reset_password.subtext' | t }}</p>

    <div class="customer-form">
      {%- form 'recover_customer_password' -%}
        {%- if form.posted_successfully? -%}
          <div class="customer-form__success" role="status">
            {{ 'customer.reset_password.success' | t }}
          </div>
        {%- endif -%}

        {%- if form.errors -%}
          <div class="customer-form__errors" role="alert">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        <div class="form-field">
          <label for="recover-email" class="form-label">
            {{ 'customer.reset_password.email' | t }}
          </label>
          <input
            type="email"
            id="recover-email"
            name="email"
            class="form-input"
            autocomplete="email"
            autocapitalize="off"
            required
          >
        </div>

        <div class="customer-form__actions">
          <button type="submit" class="btn btn-primary btn-full">
            {{ 'customer.reset_password.submit' | t }}
          </button>
        </div>
      {%- endform -%}

      <div class="customer-form__footer">
        <p>
          <a href="{{ routes.account_login_url }}">{{ 'customer.login.sign_in' | t }}</a>
        </p>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Reset Password",
  "tag": "section",
  "class": "section-customer-reset-password"
}
{% endschema %}
