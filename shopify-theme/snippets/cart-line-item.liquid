{%- comment -%}
  Cart line item display.
  Usage: {% render 'cart-line-item', item: item %}
{%- endcomment -%}

<div class="cart-item" data-cart-item data-key="{{ item.key }}">
  <a href="{{ item.url }}" class="cart-item__image-link" aria-label="{{ item.product.title }}">
    {%- if item.image -%}
      <img
        src="{{ item.image | image_url: width: 120 }}"
        alt="{{ item.image.alt | escape | default: item.product.title | escape }}"
        width="60"
        height="60"
        loading="lazy"
        class="cart-item__image"
      >
    {%- else -%}
      <div class="cart-item__image-placeholder">
        {% render 'icon-cart' %}
      </div>
    {%- endif -%}
  </a>

  <div class="cart-item__details">
    <a href="{{ item.url }}" class="cart-item__title">
      {{ item.product.title }}
    </a>

    {%- if item.variant.title != 'Default Title' -%}
      <p class="cart-item__variant">{{ item.variant.title }}</p>
    {%- endif -%}

    {%- if item.selling_plan_allocation -%}
      <p class="cart-item__variant">{{ item.selling_plan_allocation.selling_plan.name }}</p>
    {%- endif -%}

    <div class="cart-item__price">
      {%- if item.original_line_price != item.final_line_price -%}
        <s class="cart-item__price-compare">{{ item.original_line_price | money }}</s>
      {%- endif -%}
      <span class="cart-item__price-current">{{ item.final_line_price | money }}</span>
    </div>

    <div class="cart-item__actions">
      <div class="cart-item__quantity" data-quantity-controls>
        <button
          type="button"
          class="cart-item__qty-btn"
          data-qty-minus
          data-key="{{ item.key }}"
          aria-label="{{ 'cart.quantity' | t }}: {{ 'general.pagination.previous' | t }}"
        >
          <span aria-hidden="true">&minus;</span>
        </button>

        <input
          type="number"
          class="cart-item__qty-input"
          value="{{ item.quantity }}"
          min="0"
          max="{{ item.variant.inventory_quantity | default: 99 }}"
          data-qty-input
          data-key="{{ item.key }}"
          aria-label="{{ 'cart.quantity' | t }}"
        >

        <button
          type="button"
          class="cart-item__qty-btn"
          data-qty-plus
          data-key="{{ item.key }}"
          aria-label="{{ 'cart.quantity' | t }}: {{ 'general.pagination.next' | t }}"
        >
          <span aria-hidden="true">&plus;</span>
        </button>
      </div>

      <button
        type="button"
        class="cart-item__remove"
        data-remove-item
        data-key="{{ item.key }}"
        aria-label="{{ 'cart.remove' | t }}: {{ item.product.title }}"
      >
        {{ 'cart.remove' | t }}
      </button>
    </div>
  </div>
</div>
