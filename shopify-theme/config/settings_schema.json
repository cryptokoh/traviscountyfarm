        "default": "drawer",
        "info": "Drawer slides out from the right. Page redirects to /cart."
      }
    ]
  },
  {
    "name": "Products",
    "settings": [
      {
        "type": "select",
        "id": "coming_soon_method",
        "label": "Coming soon method",
        "options": [
          { "value": "tag", "label": "Product tag \"coming-soon\"" },
          { "value": "metafield", "label": "Product metafield" }
        ],
        "default": "tag",
        "info": "How to mark products as coming soon. Tag method is simplest."
      },
      {
        "type": "checkbox",
        "id": "show_product_badges",
